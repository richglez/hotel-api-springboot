name: CI Pipeline

on:
  push:
    branches: [main, develop]
  pull_request:
    branches: [main]

jobs:
  # ─────────────────────────────────────────
  # JOB 1: Tests del backend (Spring Boot)
  # ─────────────────────────────────────────
  backend-ci:
    name: Backend — Build & Test
    runs-on: ubuntu-latest

    # Levanta una PostgreSQL real para los tests de integración
    services:
      postgres:
        image: postgres:16
        env:
          POSTGRES_DB: hotel_test
          POSTGRES_USER: postgres
          POSTGRES_PASSWORD: postgres
        ports:
          - 5432:5432
        # Espera a que Postgres esté listo antes de correr tests
        options: >-
          --health-cmd pg_isready
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5

    steps:
      - name: Checkout código
        uses: actions/checkout@v4

      - name: Setup Java 21
        uses: actions/setup-java@v4
        with:
          java-version: '21'
          distribution: 'temurin'   # OpenJDK de Adoptium, el más usado en CI
          cache: 'maven'            # Cachea dependencias de Maven ⚡

      # Variables de entorno que Spring Boot necesita para los tests
      - name: Correr tests
        env:
          SPRING_DATASOURCE_URL: jdbc:postgresql://localhost:5432/hotel_test
          SPRING_DATASOURCE_USERNAME: postgres
          SPRING_DATASOURCE_PASSWORD: postgres
          JWT_SECRET: ${{ secrets.JWT_SECRET }}
        run: ./mvnw verify   # compile + test + integration-test en un solo comando

      # Guarda el .jar como artefacto para usarlo en el job de Docker
      - name: Guardar JAR
        uses: actions/upload-artifact@v4
        with:
          name: app-jar
          path: target/*.jar
          retention-days: 1   # Solo necesitamos el JAR hoy


  # ─────────────────────────────────────────
  # JOB 2: Build del frontend (React + TS)
  # ─────────────────────────────────────────
  frontend-ci:
    name: Frontend — Lint, Test & Build
    runs-on: ubuntu-latest

    defaults:
      run:
        working-directory: ./frontend   # Todos los run corren desde /frontend

    steps:
      - name: Checkout código
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4     # ← nombre correcto de la action
        with:
          node-version: '20'
          cache: 'npm'
          cache-dependency-path: frontend/package-lock.json

      - name: Instalar dependencias
        run: npm ci                     # ← más estricto que npm install, ideal para CI

      - name: Lint
        run: npm run lint

      - name: Tests
        run: npm test -- --watchAll=false   # --watchAll=false para que no quede esperando

      - name: Build
        run: npm run build
        env:
          VITE_API_URL: ${{ secrets.VITE_API_URL }}   # Si usas variables de entorno en Vite


  # ─────────────────────────────────────────
  # JOB 3: Build de imagen Docker
  # Solo corre si backend-ci y frontend-ci pasaron
  # ─────────────────────────────────────────
  docker-build:
    name: Docker — Build Image
    runs-on: ubuntu-latest
    needs: [backend-ci, frontend-ci]   # ⚠️ depende de ambos jobs

    steps:
      - name: Checkout código
        uses: actions/checkout@v4

      # Descarga el JAR que guardamos en backend-ci
      - name: Descargar JAR
        uses: actions/download-artifact@v4
        with:
          name: app-jar
          path: target/

      - name: Setup Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Build imagen Docker
        uses: docker/build-push-action@v5
        with:
          context: .
          push: false       # Solo build, no push. El push va en cd.yml
          tags: hotel-api:${{ github.sha }}
          cache-from: type=gha   # Cache de capas Docker entre runs ⚡
          cache-to: type=gha,mode=max