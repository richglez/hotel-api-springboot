# =======================================================
# HOTEL API - ENVIRONMENT VARIABLES EXAMPLE
# Copy this file and rename it to .env
# Never commit .env or .env.production to version control
# =======================================================


# ========== DATABASE ==========
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_HOST=postgres           # 'postgres' for Docker Compose, host for local
DB_PORT=5432
DB_NAME=hotel_db
DATABASE_URL=jdbc:postgresql://postgres:5432/hotel_db


# ========== JWT ==========
# Generate with: openssl rand -base64 64
JWT_SECRET=your-secret-key-minimum-32-characters-long


# ========== APP ==========
APP_ENV=development
APP_PORT=8080
SPRING_PROFILES_ACTIVE=local   # local | prod


# ========== CORS ==========
FRONTEND_URL=http://localhost:5173


# ========== FRONTEND (Vite) ==========
# Points to the backend API
VITE_API_BASE_URL=http://localhost:8080/api


# =======================================================
# RAILWAY PRODUCTION - set these in Railway dashboard
# =======================================================
# SPRING_DATASOURCE_URL=jdbc:postgresql://host:5432/railway
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=
# SPRING_PROFILES_ACTIVE=prod
# JWT_SECRET=
# FRONTEND_URL=https://your-frontend.up.railway.app
#
# Railway Build Arguments (frontend service):
# VITE_API_BASE_URL=https://your-backend.up.railway.app/api
# =======================================================